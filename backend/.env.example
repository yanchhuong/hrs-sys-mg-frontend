NODE_ENV=development
PORT=4000

# Postgres connection string. In Docker this is usually postgres://... pointing at the db service.
DATABASE_URL=postgresql://hrms:hrms@localhost:5432/hrms

# 32+ chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# Cloud or local. Drives login tenant resolution and sync behavior.
DEPLOYMENT_MODE=cloud

# Only used when DEPLOYMENT_MODE=local
LOCAL_TENANT_SLUG=local-site
LOCAL_TENANT_NAME=Local Branch
LOCAL_API_KEY=

# Comma-separated list of allowed CORS origins (cloud) / usually just the local UI (local)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
