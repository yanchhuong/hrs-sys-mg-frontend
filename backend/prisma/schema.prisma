// HRMS backend schema
//
// Used for both cloud (multi-tenant) and local (single-tenant) deployments.
// Every record is scoped by tenantId so the same schema serves both variants.
// For local installs, tenantId is pinned at boot from LOCAL_TENANT_ID env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  apiKey      String   @unique
  planTier    String   @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  employees   Employee[]
  departments Department[]
  attendance  Attendance[]
  otRequests  OTRequest[]
  payroll     PayrollItem[]
  contracts   Contract[]
  exceptions  AttendanceException[]
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String
  passwordHash  String
  role          String    // admin | manager | employee | custom-*
  employeeId    String?
  departmentId  String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee? @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Org
// ---------------------------------------------------------------------------
model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  managerId   String?
  createdAt   DateTime @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Employee {
  id                 String   @id @default(cuid())
  tenantId           String
  empNo              String
  name               String
  khmerName          String?
  email              String
  position           String
  departmentId       String?
  joinDate           DateTime
  status             String   @default("active")
  contactNumber      String?
  baseSalary         Decimal  @db.Decimal(12, 2)
  managerId          String?
  profileImage       String?
  gender             String?
  dateOfBirth        DateTime?
  placeOfBirth       String?
  currentAddress     String?
  nffNo              String?
  tid                String?
  contractExpireDate DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department         Department?   @relation(fields: [departmentId], references: [id])
  attendance         Attendance[]
  otRequests         OTRequest[]
  payrollItems       PayrollItem[]
  contracts          Contract[]
  exceptions         AttendanceException[]
  users              User[]

  @@unique([tenantId, empNo])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, departmentId])
}

// ---------------------------------------------------------------------------
// Attendance
// ---------------------------------------------------------------------------
model Attendance {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime @db.Date
  morningIn   String?
  morningOut  String?
  noonIn      String?
  noonOut     String?
  otHours     Decimal? @db.Decimal(5, 2)
  workHours   Decimal? @db.Decimal(5, 2)
  status      String
  notes       String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
}

model AttendanceException {
  id               String   @id @default(cuid())
  tenantId         String
  employeeId       String
  date             DateTime @db.Date
  type             String
  originalCheckIn  String?
  originalCheckOut String?
  correctedCheckIn String?
  correctedCheckOut String?
  reason           String
  status           String   @default("pending")
  submittedById    String
  approvedById     String?
  submittedAt      DateTime @default(now())
  approvedAt       DateTime?

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// ---------------------------------------------------------------------------
// OT / Payroll / Contracts
// ---------------------------------------------------------------------------
model OTRequest {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  date         DateTime @db.Date
  hours        Decimal  @db.Decimal(5, 2)
  reason       String
  status       String   @default("pending")
  isWeekend    Boolean  @default(false)
  isHoliday    Boolean  @default(false)
  requestedAt  DateTime @default(now())
  approvedById String?
  approvedAt   DateTime?

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model PayrollItem {
  id                    String   @id @default(cuid())
  tenantId              String
  employeeId            String
  month                 String   // YYYY-MM
  baseSalary            Decimal  @db.Decimal(12, 2)
  positionAllowance     Decimal? @db.Decimal(12, 2)
  evaluationAllowance   Decimal? @db.Decimal(12, 2)
  otHours               Decimal  @db.Decimal(6, 2) @default(0)
  otPay                 Decimal  @db.Decimal(12, 2) @default(0)
  firstSalaryDeduction  Decimal? @db.Decimal(12, 2)
  nssfPension           Decimal? @db.Decimal(12, 2)
  taxOnSalary           Decimal? @db.Decimal(12, 2)
  otherDeductions       Decimal? @db.Decimal(12, 2)
  deductions            Decimal  @db.Decimal(12, 2)
  totalPay              Decimal  @db.Decimal(12, 2)
  totalEarnings         Decimal  @db.Decimal(12, 2)
  currency              String   @default("USD")
  payrollAccount        String?
  generatedAt           DateTime @default(now())
  approvedById          String?

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee              Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, month])
  @@index([tenantId, month])
}

model Contract {
  id             String   @id @default(cuid())
  tenantId       String
  employeeId     String
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  status         String   @default("active")
  contractType   String
  salary         Decimal? @db.Decimal(12, 2)
  notes          String?
  renewedFromId  String?
  createdAt      DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// ---------------------------------------------------------------------------
// Sync bookkeeping (used by local-install sync worker)
// ---------------------------------------------------------------------------
model SyncOutbox {
  id         String   @id @default(cuid())
  tenantId   String
  entity     String   // e.g. "Employee", "Attendance"
  entityId   String
  operation  String   // create | update | delete
  payload    Json
  createdAt  DateTime @default(now())
  sentAt     DateTime?
  ackedAt    DateTime?
  retries    Int      @default(0)
  lastError  String?

  @@index([tenantId, sentAt])
}
