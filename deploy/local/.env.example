# HRMS — local deployment
# Copy to .env and fill in real values.

# --- Local UI ----------------------------------------------------------------
# Port exposed on the host machine. Point users at http://localhost:${LOCAL_PORT}
LOCAL_PORT=8080

# --- Tenant identity (pinned at boot) ---------------------------------------
# Human-friendly slug that identifies THIS site in the cloud.
LOCAL_TENANT_SLUG=local-site
LOCAL_TENANT_NAME=Local Branch

# Provided by your cloud admin — paste the long random key you received.
# Leave blank on first boot if you're running fully offline; seed will mint one locally.
LOCAL_API_KEY=

# --- Database ----------------------------------------------------------------
# Defaults are fine for local — the DB is not reachable from outside Docker.
POSTGRES_USER=hrms
POSTGRES_PASSWORD=hrms
POSTGRES_DB=hrms

# --- Secrets -----------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars

# --- Sync (optional) ---------------------------------------------------------
# Set to your cloud URL to enable data sync. Leave empty to run fully offline.
# Enable by adding --profile sync when starting compose.
CLOUD_API_URL=
CLOUD_API_KEY=
SYNC_INTERVAL_SECONDS=60
