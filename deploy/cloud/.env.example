# HRMS — cloud deployment
# Copy to .env and fill in real values. Never commit .env.

# --- Public ------------------------------------------------------------------
# DNS name that points at this server. Caddy will fetch a TLS cert for it.
PUBLIC_HOST=hrms.example.com
# Matching https:// origin used for CORS.
PUBLIC_ORIGIN=https://hrms.example.com
# Email for Let's Encrypt account + expiry warnings.
ACME_EMAIL=admin@example.com

# --- Database ----------------------------------------------------------------
POSTGRES_USER=hrms
POSTGRES_PASSWORD=CHANGE_ME_long_random_password
POSTGRES_DB=hrms

# --- Secrets -----------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars
