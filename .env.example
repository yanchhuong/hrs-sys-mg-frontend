# HRMS Frontend — local dev overrides
# Copy to .env.local (gitignored) and tweak as needed.

# Backend base URL. No trailing slash.
VITE_API_BASE=http://localhost:4000

# Set to "true" to run the UI entirely off src/app/data/mockData.ts
# — useful for offline demos and when the backend is unavailable.
# When false (default), the UI calls the real API and login requires
# a seeded user (admin@example.com / admin123 out of the box).
VITE_USE_MOCKS=false
